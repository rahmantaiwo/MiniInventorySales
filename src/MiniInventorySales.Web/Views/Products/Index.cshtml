@model ProductIndexViewModel

@{
    ViewData["Title"] = "Products";
    Layout = "_Layout";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
    <div>
        <h2 class="mb-1">Product Management</h2>
        <p class="text-muted mb-0">Manage inventory, pricing, and availability.</p>
    </div>
    <div class="mt-3 mt-md-0">
        <a class="btn btn-primary" asp-action="Create">
            <i class="bi bi-plus-lg me-1"></i> New Product
        </a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-muted">Total Products</div>
                        <div class="fs-4 fw-semibold">@Model.Paged.TotalCount</div>
                    </div>
                    <i class="bi bi-box-seam fs-3 text-primary"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-muted">Active (This Page)</div>
                        <div class="fs-4 fw-semibold">@Model.PageActiveCount</div>
                    </div>
                    <i class="bi bi-check-circle fs-3 text-success"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-muted">Low Stock (This Page)</div>
                        <div class="fs-4 fw-semibold">@Model.PageLowStockCount</div>
                    </div>
                    <i class="bi bi-exclamation-triangle fs-3 text-warning"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Search</label>
                <input class="form-control" name="Search" value="@Model.Query.Search" placeholder="Search by SKU or name" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Status</label>
                <select class="form-select" name="IsActive">
                    <option value="" selected="@(Model.Query.IsActive is null)">All</option>
                    <option value="true" selected="@(Model.Query.IsActive == true)">Active</option>
                    <option value="false" selected="@(Model.Query.IsActive == false)">Inactive</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Category</label>
                <select class="form-select" name="CategoryId">
                    @foreach (var option in Model.CategoryOptions)
                    {
                        <option value="@option.Value" selected="@option.Selected">@option.Text</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Page Size</label>
                <select class="form-select" name="PageSize">
                    <option value="5" selected="@(Model.Query.PageSize == 5)">5</option>
                    <option value="10" selected="@(Model.Query.PageSize == 10)">10</option>
                    <option value="20" selected="@(Model.Query.PageSize == 20)">20</option>
                    <option value="50" selected="@(Model.Query.PageSize == 50)">50</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-outline-primary w-100">
                    <i class="bi bi-search me-1"></i> Filter
                </button>
            </div>
        </form>
    </div>
</div>

@if (Model.Paged.Items.Count == 0)
{
    <div class="alert alert-info">
        No products found. <a asp-action="Create">Create a new product</a> to get started.
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Image</th>
                        <th>SKU</th>
                        <th>Name</th>
                        <th>Category</th>
                        <th class="text-end">Selling Price</th>
                        <th class="text-end">Stock</th>
                        <th class="text-end">Reorder</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Paged.Items)
                {
                    var isLow = item.QuantityInStock <= item.ReorderLevel;
                    <tr>
                        <td style="width: 80px;">
                            @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" alt="@item.Name" class="img-fluid rounded" style="max-height: 50px;" />
                            }
                            else
                            {
                                <div class="bg-light border rounded d-flex align-items-center justify-content-center" style="width:50px;height:50px;">
                                    <i class="bi bi-image text-muted"></i>
                                </div>
                            }
                        </td>
                        <td class="fw-semibold">@item.Sku</td>
                        <td>@item.Name</td>
                        <td>@item.CategoryName</td>
                        <td class="text-end">@item.SellingPrice.ToString("N2")</td>
                        <td class="text-end">
                            <span class="@(isLow ? "text-danger fw-semibold" : "")">@item.QuantityInStock</span>
                        </td>
                        <td class="text-end">@item.ReorderLevel</td>
                        <td>
                            @if (item.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                            @if (isLow)
                            {
                                <span class="badge bg-warning text-dark ms-1">Low Stock</span>
                            }
                        </td>
                        <td class="text-end">
                            <div class="btn-group" role="group">
                                <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.Id">Details</a>
                                <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                                @if (item.IsActive)
                                {
                                    <form asp-action="Deactivate" asp-route-id="@item.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Deactivate this product?');">
                                            Deactivate
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>

        <div class="card-body d-flex flex-column flex-md-row justify-content-between align-items-md-center">
            <div class="text-muted mb-2 mb-md-0">
                Page @Model.Paged.PageNumber of @Model.Paged.TotalPages
            </div>
            @if (Model.Paged.TotalPages > 1)
            {
                <nav aria-label="Product pagination">
                    <ul class="pagination mb-0">
                        <li class="page-item @(Model.Paged.PageNumber <= 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="Index"
                               asp-route-PageNumber="@(Model.Paged.PageNumber - 1)"
                               asp-route-PageSize="@Model.Query.PageSize"
                               asp-route-Search="@Model.Query.Search"
                               asp-route-IsActive="@Model.Query.IsActive"
                               asp-route-CategoryId="@Model.Query.CategoryId">Prev</a>
                        </li>
                        @for (var i = 1; i <= Model.Paged.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.Paged.PageNumber ? "active" : "")">
                                <a class="page-link" asp-action="Index"
                                   asp-route-PageNumber="@i"
                                   asp-route-PageSize="@Model.Query.PageSize"
                                   asp-route-Search="@Model.Query.Search"
                                   asp-route-IsActive="@Model.Query.IsActive"
                                   asp-route-CategoryId="@Model.Query.CategoryId">@i</a>
                            </li>
                        }
                        <li class="page-item @(Model.Paged.PageNumber >= Model.Paged.TotalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="Index"
                               asp-route-PageNumber="@(Model.Paged.PageNumber + 1)"
                               asp-route-PageSize="@Model.Query.PageSize"
                               asp-route-Search="@Model.Query.Search"
                               asp-route-IsActive="@Model.Query.IsActive"
                               asp-route-CategoryId="@Model.Query.CategoryId">Next</a>
                        </li>
                    </ul>
                </nav>
            }
        </div>
    </div>
}
