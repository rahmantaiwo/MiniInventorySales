@model MiniInventorySales.Application.DTOs.Products.ProductDetailsDto

@{
    ViewData["Title"] = "Product Details";
    Layout = "_Layout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">@Model.Name</h2>
        <p class="text-muted mb-0">SKU: @Model.Sku</p>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
        <a class="btn btn-outline-secondary" asp-action="Index">Back to Products</a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card shadow-sm">
            <div class="card-body text-center">
                @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid rounded" style="max-height: 220px;" />
                }
                else
                {
                    <div class="bg-light border rounded p-5 text-muted">No image uploaded</div>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="text-muted">Category</div>
                        <div class="fs-6 fw-semibold">@Model.CategoryName</div>
                    </div>
                    <div class="col-md-6">
                        <div class="text-muted">Status</div>
                        <div>
                            @if (Model.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="text-muted">Cost Price</div>
                        <div class="fs-5 fw-semibold">@Model.CostPrice.ToString("N2")</div>
                    </div>
                    <div class="col-md-6">
                        <div class="text-muted">Selling Price</div>
                        <div class="fs-5 fw-semibold">@Model.SellingPrice.ToString("N2")</div>
                    </div>
                    <div class="col-md-6">
                        <div class="text-muted">Quantity In Stock</div>
                        <div class="fs-5 fw-semibold">@Model.QuantityInStock</div>
                    </div>
                    <div class="col-md-6">
                        <div class="text-muted">Reorder Level</div>
                        <div class="fs-5 fw-semibold">@Model.ReorderLevel</div>
                    </div>
                    <div class="col-md-6">
                        <div class="text-muted">Created At</div>
                        <div>@Model.CreatedAt.ToString("MMM d, yyyy")</div>
                    </div>
                    <div class="col-md-6">
                        <div class="text-muted">Low Stock</div>
                        <div>
                            @if (Model.QuantityInStock <= Model.ReorderLevel)
                            {
                                <span class="badge bg-warning text-dark">Yes</span>
                            }
                            else
                            {
                                <span class="badge bg-success">No</span>
                            }
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.Description))
                {
                    <div class="mt-4">
                        <div class="text-muted">Description</div>
                        <div>@Model.Description</div>
                    </div>
                }

                <div class="mt-4">
                    @if (Model.IsActive)
                    {
                        <form asp-action="Deactivate" asp-route-id="@Model.Id" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger" onclick="return confirm('Deactivate this product?');">
                                Deactivate Product
                            </button>
                        </form>
                    }
                    else
                    {
                        <div class="alert alert-secondary mb-0">This product is inactive.</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
